# Copiar os valores do .env local e configurar no Portainer
# (Stacks > ligue > Editor > Env vars) ou criar .env no servidor

# Domínio (já configurado no Cloudflare)
API_DOMAIN=api-ligue-payments.cuidai.xyz

# ============ BANCO ============
DATABASE_URL=

# ============ RABBITMQ ============
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ============ ASAAS ============
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=
ASAAS_WEBHOOK_SKIP_SIGNATURE=false
ASAAS_WEBHOOK_DEBUG=false

# ============ KOMMO CRM ============
KOMMO_ACCOUNT_ID=
KOMMO_API_TOKEN=
KOMMO_PIPELINE_B2C_ID=
KOMMO_FIELD_PRODUTO_ID=
KOMMO_FIELD_ORIGEM_ID=

# ============ DOC24 (Telemedicina) ============
DOC24_CLIENT_ID=
DOC24_CLIENT_SECRET=

# ============ EMAIL (Azure Graph) ============
USE_GRAPH_EMAIL=true
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
MAIL_FROM=no-reply@liguemedicina.com

# ============ DOCUSEAL (Contratos) ============
DOCUSEAL_API_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=

# ============ SUPABASE (Storage) ============
SUPABASE_CONTRACTS_PROJECT_URL=
SUPABASE_CONTRACTS_BUCKET=contracts
SUPABASE_CONTRACTS_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_URL=

# ============ DATADOG ============
DD_API_KEY=
DD_ENV=production
DD_HOSTNAME=ligue-swarm
