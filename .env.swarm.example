# Copiar para .env.swarm e preencher no servidor
# Ou configurar diretamente nas Env vars do Portainer

# Imagens (após build + push para o registry)
REGISTRY_IMAGE=SEU_REGISTRY/ligue-payments:latest
RABBITMQ_IMAGE=SEU_REGISTRY/ligue-rabbitmq:latest

# Domínios (devem apontar para o IP do servidor no DNS)
DOMAIN=seudominio.com
API_DOMAIN=api.seudominio.com

# Traefik
ACME_EMAIL=seuemail@example.com
# Gerar com: echo $(htpasswd -nb admin SUASENHA) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xxxxxx

# App
DATABASE_URL=postgres://user:pass@host:5432/ligue_payments
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
ASAAS_API_KEY=
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@seudominio.com
DD_API_KEY=
DD_ENV=production
DD_HOSTNAME=ligue-swarm
